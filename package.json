{
  "name": "sliding-weather",
  "author": "vincentp",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "scripts": {
    "test": "bun test",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "bun run build:ts && pebble build",
    "clean": "rm -rf dist/ && pebble clean",
    "lint": "biome lint src/pkjs test",
    "format": "biome format --write src/pkjs test",
    "check": "biome check --write src/pkjs test",
    "typecheck": "tsc --noEmit",
    "emu-settings": "bun run scripts/load-emu-settings.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
  "pebble": {
    "displayName": "Sliding Weather",
    "longName": "Sliding Weather",
    "shortName": "Sliding Weather",
    "uuid": "10c972fe-7002-42af-8ecb-2b9ab40ae589",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": [
      "configurable",
      "location"
    ],
    "messageKeys": [
      "TEMPERATURE_IN_C",
      "CONDITIONS",
      "BACKGROUND_COLOR",
      "WEATHER_FREQUENCY",
      "USE_CELSIUS",
      "DISPLAY_WEATHER",
      "GET_WEATHER",
      "TEMPERATURE",
      "CONDITION_CODE",
      "VIBBRATE_BT_STATUS",
      "WEATHER_USE_GPS",
      "WEATHER_LOCATION",
      "JS_READY",
      "WD_COLOR",
      "HR_COLOR",
      "MIN_COLOR"
    ],
    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu-icon.png"
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_APLITE",
          "file": "images/preview-aplite.png",
          "targetPlatforms": [
            "aplite"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_BASALT",
          "file": "images/preview-basalt.png",
          "targetPlatforms": [
            "basalt"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_CHALK",
          "file": "images/preview-chalk.png",
          "targetPlatforms": [
            "chalk"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_DIORITE",
          "file": "images/preview-diorite.png",
          "targetPlatforms": [
            "diorite"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_EMERY",
          "file": "images/preview-emery.png",
          "targetPlatforms": [
            "emery"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_FLINT",
          "file": "images/preview-flint.png",
          "targetPlatforms": [
            "flint"
          ]
        },
        {
          "type": "png",
          "name": "IMAGE_PREVIEW_GABBRO",
          "file": "images/preview-gabbro.png",
          "targetPlatforms": [
            "gabbro"
          ]
        }
      ]
    }
  }
}
